    Public Sub searchrec()
        ColGrid.Rows.Clear()

        Dim straccount As String = txtacct1.Text + "-" + txtacct2.Text


        Dim stracctexist As String
        SQL.AddParam("@assess", "V")
        SQL.AddParam("@colstat", "P")
        '  SQL.AddParam("@userid", loginuserid)
        SQL.AddParam("@account", straccount)
        SQL.ExecQuery("Select a.recordid, b.applicationid , a.accountno, b_name , fire_local_amount, amountToPay, a.b_line, c.assess_status, c.payment_status, fullname,owneraddress,birthdate, email_add,cedula_amt from ONLINE.business_record_hdr a inner join ONLINE.business_application_tbl b on a.recordID = b.recordID inner join ONLINE.business_applicationstatus_dtl c on b.applicationID = c.applicationID inner join ONLINE.business_assessment_dtl d on b.applicationid = d.ApplicationID where c.assess_status = 'V'  and a.accountno = @account ")

        For Each r As DataRow In SQL.DBDT.Rows
            stracctexist = (r("accountno").ToString)



            ColGrid.Rows.Add(r("recordid"), r("applicationid"), r("accountno"), r("b_name"), r("amountToPay"), r("fire_local_amount"), r("cedula_amt"), r("email_add"), r("payment_status"), r("fullname"), r("owneraddress"), r("Birthdate"))
        Next

        If stracctexist = Nothing Then

            MessageBox.Show("This account has no assessment for this year", "Not Found", MessageBoxButtons.OK, MessageBoxIcon.Error)
        End If
    End Sub

