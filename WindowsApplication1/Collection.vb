    End Sub

    Private Sub BtnSearchRecord_Click(sender As Object, e As EventArgs) Handles BtnSearchRecord.Click
        ColGrid.Rows.Clear()


        Dim stracctexist As String
        SQL.AddParam("@assess", "V")
        SQL.AddParam("@colstat", "P")
        '  SQL.AddParam("@userid", loginuserid)
        SQL.AddParam("@control", txtcontrol.Text)
        SQL.ExecQuery("Select * from rpt_record_hdr a  inner join rpt_application b on a.TDN_no = b.TDN_no where a.TDN_no = @control")

        For Each r As DataRow In SQL.DBDT.Rows
            stracctexist = (r("TDN_no").ToString)
            lblid.Text = r("TDN_no").ToString


            ColGrid.Rows.Add(r("TDN_no"), r("Owner_Name"), r("Total_amt"), r("Email_add"), r("Owner_Address"), r("Location"))
        Next
    End Sub

