    Public Sub loaddata()
        SQL.AddParam("@assess", "V")
        SQL.AddParam("@colstat", "P")
        '  SQL.AddParam("@userid", loginuserid)

        SQL.ExecQuery("Select a.recordid, b.applicationid , a.accountno, b_name , b.gross_dec, a.b_line, c.assess_status, c.payment_status from business_record_hdr a inner join business_application_tbl b on a.recordID = b.recordID inner join business_applicationstatus_dtl c on b.applicationID = c.applicationID where c.assess_status = 'V' and c.payment_status = 'P' ")

        For Each r As DataRow In SQL.DBDT.Rows
            ColGrid.Rows.Add(r("recordid"), r("applicationid"), r("accountno"), r("b_name"), r("gross_dec"), r("b_line"), r("payment_status"))
        Next
    End Sub


