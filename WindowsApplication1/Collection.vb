    Public Sub LoadAdmingrid()


        Dim btneval As New DataGridViewButtonColumn
        ColGrid.Columns.Add(btneval)
        With btneval
            .HeaderText = "ACTION"
            .Width = 130
            .Name = "btneval"
            .Text = "SEND RECEIPT"
